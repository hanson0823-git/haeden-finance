# Sanity CMS Configuration
# Create a project at https://sanity.io and fill in these values
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: Sanity API token (for write access / mutations)
SANITY_API_TOKEN=your-sanity-api-token

# Optional: Contact form email (for sending enquiries)
CONTACT_EMAIL=hello@haedenfinance.com.au

# Optional: Resend API key for email sending
# RESEND_API_KEY=your-resend-api-key
